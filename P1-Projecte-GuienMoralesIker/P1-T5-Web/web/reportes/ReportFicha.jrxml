	<style name="FilaAlterna" isDefault="true" forecolor="#030303"/>
	<parameter name="ID_PRODUCTO_PADRE" class="java.math.BigDecimal"/>
	<queryString language="SQL">
		<![CDATA[SELECT 
    p_item.IT_NOM AS NOMBRE_PADRE,      -- El jefe
    pi.PI_IT_CODI AS ID_HIJO,          -- El código que querías
    c_item.IT_NOM AS NOMBRE_HIJO,      -- El nombre de la pieza
    c_item.IT_TIPUS AS TIPO_HIJO,      -- ¡Aquí está el tipo de vuelta!
    pi.PI_QUANTITAT AS CANTIDAD,
    NVL(um.NOM, 'unid.') AS UNIDAD_MEDIDA
FROM PROD_ITEM pi
JOIN ITEM p_item ON pi.PI_PR_CODI = p_item.IT_CODI
JOIN ITEM c_item ON pi.PI_IT_CODI = c_item.IT_CODI
LEFT JOIN COMPONENT c ON c_item.IT_CODI = c.CM_CODI
LEFT JOIN UNITAT_MESURA um ON c.CM_UM_CODI = um.CODI_MESURA
WHERE pi.PI_PR_CODI = $P{ID_PRODUCTO_PADRE}
ORDER BY c_item.IT_TIPUS DESC, c_item.IT_NOM ASC]]>
	</queryString>
